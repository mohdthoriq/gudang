model Variant {
  id         Int      @id @default(autoincrement())
  modelId    Int      @map("model_id")
  color      String
  size       String
  stock      Int      @default(0)
  sku        String?  @unique
  updatedAt  DateTime @updatedAt @map("updated_at")

  model      Model          @relation(fields: [modelId], references: [id])
  histories  StockHistory[] // Relasi ke riwayat stok

  @@map("variants")
}